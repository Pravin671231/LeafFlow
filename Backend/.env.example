PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/leafflow

# JWT (RS256 — paste PEM, escape newlines as \n)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_secret_here
REFRESH_TOKEN_EXPIRES_IN=7d

# OAuth
GOOGLE_CLIENT_ID=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=leafflow-media
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@leafflow.com

# Admin seed credentials
ADMIN_LOGIN_EMAIL=admin@leafflow.com
ADMIN_OTP_EMAIL=admin-otp@leafflow.com
ADMIN_PASSWORD=change_me_in_production

# App
CORS_ORIGIN=http://localhost:3001,http://localhost:5173
LOG_LEVEL=info
